/**
 * Definition for singly-linked list.
 * class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {

    public int calcLength(ListNode head)
        {
            ListNode Fast=head;
            ListNode Slow=head;
            while(Fast!=Slow)
            {
                Fast=Fast.next.next;
                Slow=Slow.next;
            }
            int length=0;
            do
            {
                Slow=Slow.next;
                length++;
            }
            while(Slow!=Fast);
            return length;
        }

    public ListNode detectCycle(ListNode head) {
        int length=0;
        ListNode fast=head;
        ListNode slow=head;

        while(fast!=null && fast.next!=null)
        {
            fast=fast.next.next;
            slow=slow.next;
            if(fast==slow)
            {
                length=calcLength(slow);
                break;
            }
        }

        if(length==0)
        {
            return null;
        }
        
        ListNode f=head;
        ListNode s=head;

        while(length>0)
        {
            s=s.next;
            length--;
        }
        while(f!=s)
        {
            f=f.next;
            s=s.next;
        }
        return f;

        
    }
}
